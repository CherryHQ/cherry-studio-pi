{
  "name": "@cherrystudio/extension-table-plus",
  "description": "table extension for tiptap forked from tiptap/extension-table",
  "version": "3.0.12",
  "homepage": "https://cherry-ai.com",
  "keywords": ["tiptap", "tiptap extension"],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./table": {
      "types": {
        "import": "./dist/table/index.d.mts",
        "require": "./dist/table/index.d.cts"
      },
      "import": "./dist/table/index.mjs",
      "require": "./dist/table/index.cjs"
    },
    "./cell": {
      "types": {
        "import": "./dist/cell/index.d.mts",
        "require": "./dist/cell/index.d.cts"
      },
      "import": "./dist/cell/index.mjs",
      "require": "./dist/cell/index.cjs"
    },
    "./header": {
      "types": {
        "import": "./dist/header/index.d.mts",
        "require": "./dist/header/index.d.cts"
      },
      "import": "./dist/header/index.mjs",
      "require": "./dist/header/index.cjs"
    },
    "./kit": {
      "types": {
        "import": "./dist/kit/index.d.mts",
        "require": "./dist/kit/index.d.cts"
      },
      "import": "./dist/kit/index.mjs",
      "require": "./dist/kit/index.cjs"
    },
    "./row": {
      "types": {
        "import": "./dist/row/index.d.mts",
        "require": "./dist/row/index.d.cts"
      },
      "import": "./dist/row/index.mjs",
      "require": "./dist/row/index.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": ["src", "dist"],
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@tiptap/core": "3.26.1",
    "@tiptap/pm": "3.26.1",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "tsdown": "^0.20.3"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.0.9",
    "@tiptap/pm": "^3.0.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CherryHQ/cherry-studio",
    "directory": "packages/extension-table-plus"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "biome format ./src/ --write && eslint --fix ./src/",
    "prepublishOnly": "pnpm build"
  },
  "packageManager": "pnpm@10.27.0"
}
